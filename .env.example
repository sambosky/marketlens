# ─────────────────────────────────────────────────────────────
# MarketLens configuration.  Copy to `.env` and adjust.
# The whole app runs with NO credentials by default (local Ollama
# + local embeddings + keyless SEC EDGAR / yfinance).
# ─────────────────────────────────────────────────────────────

# ── LLM ──────────────────────────────────────────────────────
# provider: "ollama" (local, default, no key) or "anthropic" (Claude)
MARKETLENS_LLM__PROVIDER=ollama
MARKETLENS_LLM__OLLAMA_MODEL=qwen2.5
MARKETLENS_LLM__OLLAMA_BASE_URL=http://ollama:11434
MARKETLENS_LLM__ANTHROPIC_MODEL=claude-sonnet-4-5
# Only needed when MARKETLENS_LLM__PROVIDER=anthropic:
# ANTHROPIC_API_KEY=sk-ant-...

# ── Database (Postgres + pgvector) ───────────────────────────
MARKETLENS_DB__HOST=db
MARKETLENS_DB__PORT=5432
MARKETLENS_DB__USER=postgres
MARKETLENS_DB__PASSWORD=postgres
MARKETLENS_DB__NAME=marketlens

# ── Embeddings (local, keyless) ──────────────────────────────
MARKETLENS_EMBEDDING__MODEL=BAAI/bge-small-en-v1.5

# ── Data sources ─────────────────────────────────────────────
# SEC requires a descriptive User-Agent with contact info, e.g.
#   "MarketLens demo your-name your-email@example.com"
MARKETLENS_SEC_USER_AGENT=MarketLens demo set-your-email@example.com
MARKETLENS_TICKER_UNIVERSE=NVDA,AAPL,MSFT,AMZN,TSLA

# ── API ──────────────────────────────────────────────────────
MARKETLENS_CORS_ORIGINS=http://localhost:3000
